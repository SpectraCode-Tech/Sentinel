        var consentScriptTemplateId = '019b8eea-4d8d-7ce4-9c1f-dd840736b79f';
        if (isTestEnv) {
          consentScriptTemplateId += '-test';
        }

        var script = document.createElement('script');
        script.src = `https://cdn.cookielaw.org/consent/${consentScriptTemplateId}/otSDKStub.js`;
        script.type = 'text/javascript';
        script.charset = 'UTF-8';
        script.setAttribute('data-language', "en");
        script.setAttribute('data-domain-script', consentScriptTemplateId);

        loadScript(script);

        // OptanonWrapper can be used to conditionally load scripts or execute
        // javascript depending on the consent categories that were chosen.
        // It is executed by OneTrust on each page load and whenever the user
        // modifies their consent in the Preference Center. Per OneTrust
        // docs, opt-out actions (Active to Inactive) only reflect on page refresh,
        // so we reload the page to immediately apply consent changes.
        // However, we skip reload for: (1) the initial call on page load to avoid
        // infinite loops, and (2) when new users make their initial selection since
        // Segment already waits for consent before loading.
        // See https://my.onetrust.com/s/article/UUID-518074a1-a6da-81c3-be52-bae7685d9c94?language=en_US#idm2935
        let isFirstCall = true;
        let shouldReloadOnNextCall = false;
        window.OptanonWrapper = () => {
          if (isFirstCall) {
            // First call on page load - check if user already made a selection previously.
            // If yes (returning user), we'll reload on their next preference change.
            // If no (new user), we'll skip reload on their initial selection.
            shouldReloadOnNextCall = window.OneTrust?.IsAlertBoxClosed();
            isFirstCall = false;
          } else {
            // Subsequent calls triggered by user changing preferences
            if (shouldReloadOnNextCall) {
              // Either a returning user or a new user changing after initial selection - reload
              window.location.reload();
            } else {
              // New user making initial selection - skip reload but enable it for future changes
              shouldReloadOnNextCall = true;
            }
          }
        }
